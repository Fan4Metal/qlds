// ****************************************************************************
// Local secrets & personal data — NOT committed to git (see .gitignore).
// This file is exec'd at the end of autoexec.cfg and overrides earlier values.
// Copy this file to secret.cfg and fill in your own values.
// ****************************************************************************

// --- Passwords ---------------------------------------------------------------
// Used by rcon/stats tooling and the reserved player slots.
set zmq_rcon_password "CHANGE_ME_RCON"
set zmq_stats_password "CHANGE_ME_STATS"
set sv_privatePassword "CHANGE_ME_PRIVATE"

// --- Owner / admin -----------------------------------------------------------
// Your SteamID64. Find it at https://steamid.io. minqlx refuses admin
// commands unless this is set.
set qlx_owner "00000000000000000"

// --- Server identity / branding ----------------------------------------------
set sv_hostname "My Quake Live Duel Server"
set qlx_serverBrandTopField "^7My Duel Server"
set qlx_serverBrandBottomField "^7Location"
