# --- Secrets & personal data -------------------------------------------------
# Local, untracked. Copy the matching *.example file and fill in your values.
ffa/secret.cfg
instagib_ffa_pql/secret.cfg
access.txt

# --- Steam Workshop content --------------------------------------------------
# The server downloads Workshop items (IDs in ffa/workshop.txt) at startup into
# the `steamapps` Docker volume, so no content lives in the working tree. This
# guard catches any stray local steamcmd cache placed here by mistake.
ffa/steamapps/
instagib_ffa_pql/steamapps/

# --- Redis backups -----------------------------------------------------------
# Database snapshots from scripts/backup-redis.sh — may contain player data.
backups/
*.rdb

# --- OS / editor junk --------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store
*.swp
.idea/
.vscode/
